# Production domain used for canonical tags, Open Graph URLs, JSON-LD, robots.txt, and sitemap.xml.
# Use the full site origin with no trailing slash.
# On Vercel, the build can also fall back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL
# if Automatically expose System Environment Variables is enabled.
VITE_SITE_URL=https://your-domain.com
